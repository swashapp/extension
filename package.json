{
  "name": "swash-extension",
  "version": "3.0.0",
  "type": "module",
  "repository": {
    "url": "https://github.com/swashapp/extension.git"
  },
  "staticFiles": {
    "staticPath": [
      "src/core/configs",
      "src/core/modules"
    ]
  },
  "scripts": {
    "clean": "shx rm -rf dist src/manifest.json",
    "clean:deep": "shx rm -rf dist .parcel-cache src/manifest.json",
    "precopy": "shx mkdir -p dist/",
    "copy": "shx cp -r src/static dist/",
    "parcel:dev": "parcel watch --no-content-hash --no-hmr src/manifest.json src/ui/*.html --target dev",
    "parcel:prod": "parcel build src/manifest.json src/ui/*.html --target prod --reporter @parcel/reporter-bundle-analyzer",
    "build:scripts:dev": "parcel build src/core/scripts/{*,inpage/*}.ts --target script-dev",
    "build:scripts:prod": "parcel build src/core/scripts/{*,inpage/*}.ts --target script-prod --reporter @parcel/reporter-bundle-analyzer",
    "build:firefox:manifest": "node dev/prepare.js -b firefox -m 2",
    "build:firefox:dev": "run-s clean:deep build:scripts:dev build:firefox:manifest copy parcel:dev",
    "build:firefox:prod": "run-s clean:deep build:scripts:prod build:firefox:manifest copy parcel:prod",
    "build:chrome:manifest": "node dev/prepare.js -b chrome -m 3",
    "build:chrome:dev": "run-s clean:deep build:scripts:dev build:chrome:manifest copy parcel:dev",
    "build:chrome:prod": "run-s clean:deep build:scripts:prod build:chrome:manifest copy parcel:prod",
    "build:dev": "run-s build:chrome:dev",
    "build:prod": "run-s build:chrome:prod",
    "run:firefox": "web-ext run --source-dir dist",
    "run:chrome": "web-ext run -t chromium --source-dir dist",
    "run:dev": "run-s run:chrome",
    "run:prod": "run -s run:chrome",
    "run": "run-s run:chrome",
    "pack:firefox": "node dev/release.js firefox",
    "pack:chrome": "node dev/release.js chrome",
    "release:firefox": "run-s build:firefox:prod pack:firefox",
    "release:chrome": "run-s build:chrome:prod pack:chrome",
    "release": "run-s release:*",
    "format": "prettier --write '{src,subgraph}/**/*.{js,jsx,ts,tsx,css,json}' '*.{js,jsx,ts,tsx,css,json}'",
    "lint:code": "eslint src/**/*.ts --fix",
    "lint:extension": "web-ext lint dist",
    "subgraph:codegen": "graph codegen subgraph/subgraph.yaml --output-dir subgraph/generated",
    "subgraph:build": "graph build subgraph/subgraph.yaml --output-dir subgraph/build",
    "subgraph:deploy": "graph deploy subgraph/subgraph.yaml --node https://api.thegraph.com/deploy/ subgraph/swashdataunion --output-dir subgraph/build",
    "subgraph:create-local": "graph create subgraph/subgraph.yaml --node http://localhost:8020/ subgraph/swashdataunion",
    "subgraph:remove-local": "graph remove subgraph/subgraph.yaml --node http://localhost:8020/ subgraph/swashdataunion",
    "subgraph:deploy-local": "graph deploy subgraph/subgraph.yaml --node http://localhost:8020/ --ipfs http://localhost:5001 subgraph/swashdataunion --output-dir subgraph/build"
  },
  "dependencies": {
    "@emotion/react": "11.11.4",
    "@emotion/styled": "11.11.5",
    "@mui/material": "5.15.14",
    "@mui/styles": "5.15.14",
    "browserify-cipher": "1.0.1",
    "create-hash": "1.2.0",
    "dayjs": "1.11.13",
    "ethers": "6.13.3",
    "jsonpath-plus": "6.0.1",
    "jsonpointer": "5.0.1",
    "jsontokens": "4.0.1",
    "jsstore": "4.7.3",
    "mdbreact": "5.2.0",
    "pbkdf2": "3.1.2",
    "prop-types": "15.8.1",
    "react": "18.2.0",
    "react-collapse": "5.1.1",
    "react-copy-to-clipboard": "5.1.0",
    "react-dom": "18.2.0",
    "react-json-view-lite": "^1.5.0",
    "react-phone-input-2": "^2.15.1",
    "react-qr-code": "2.0.15",
    "react-router-dom": "6.22.3",
    "react-share": "5.1.0",
    "react-swipeable-views": "0.14.0",
    "react-toastify": "10.0.5",
    "react-widgets": "5.8.4",
    "reactstrap": "9.2.2",
    "remove": "0.1.5",
    "use-persisted-state": "0.3.3",
    "webextension-polyfill": "0.10.0"
  },
  "devDependencies": {
    "@graphprotocol/graph-cli": "0.84.0",
    "@graphprotocol/graph-ts": "0.35.1",
    "@mui/codemod": "5.15.14",
    "@parcel/config-webextension": "2.12.0",
    "@parcel/reporter-bundle-analyzer": "2.12.0",
    "@parcel/transformer-image": "2.12.0",
    "@types/create-hash": "^1.2.6",
    "@types/react": "18.2.74",
    "@types/react-copy-to-clipboard": "5.0.7",
    "@types/react-dom": "18.2.23",
    "@types/react-swipeable-views": "0.13.5",
    "@types/use-persisted-state": "0.3.4",
    "@types/webextension-polyfill": "0.10.7",
    "@typescript-eslint/eslint-plugin": "7.5.0",
    "@typescript-eslint/parser": "7.5.0",
    "arg": "5.0.2",
    "crypto-browserify": "^3.12.0",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-import": "2.29.1",
    "eslint-plugin-react": "7.34.1",
    "eslint-plugin-react-hooks": "4.6.0",
    "npm-run-all": "4.1.5",
    "parcel": "2.12.0",
    "parcel-resolver-ignore": "2.2.0",
    "prettier": "3.2.5",
    "process": "0.11.10",
    "shx": "0.3.4",
    "stream-browserify": "^3.0.0",
    "typescript": "5.4.3",
    "vm-browserify": "^1.1.2",
    "web-ext": "7.11.0"
  },
  "resolutions": {
    "@types/react": "18.2.74"
  },
  "targets": {
    "dev": {
      "distDir": "dist",
      "optimize": false,
      "sourceMap": {
        "inline": true,
        "inlineSources": true
      }
    },
    "prod": {
      "distDir": "dist",
      "optimize": true,
      "sourceMap": false
    },
    "script-dev": {
      "distDir": "dist/scripts",
      "optimize": false,
      "sourceMap": {
        "inline": true,
        "inlineSources": true
      }
    },
    "script-prod": {
      "distDir": "dist/scripts",
      "optimize": true,
      "sourceMap": false
    }
  },
  "parcelIgnore": [
    "static/fonts/*.*",
    "static/images/*.*"
  ]
}
